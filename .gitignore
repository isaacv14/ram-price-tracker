# --- Python Environment ---
__pycache__/
*.py[cod]
*$py.class
.venv/
env/
venv/
ENV/

# --- Sensitive Data & Credentials ---
# Never commit your passwords or API keys!
.env
*.env
secrets.json
config.ini
*.pem

# --- ETL Data Files (Local Storage) ---
# Ignore local data dumps to prevent bloating the repo
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep
*.csv
*.xlsx
*.jsonl
*.parquet
*.sql
*.log

# --- IDEs & OS ---
.vscode/
.idea/
.DS_Store
Thumbs.db